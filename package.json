{
  "name": "nexus",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=@nexus/api",
    "dev:web": "npm run dev --workspace=@nexus/web",
    "build:web": "npm run build --workspace=@nexus/web",
    "start:api": "npm run start --workspace=@nexus/api"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
