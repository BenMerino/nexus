{
  "name": "nexus",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c green,cyan --restart-tries -1 --restart-after 1000 \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev --workspace=@nexus/api",
    "dev:web": "npm run dev --workspace=@nexus/web",
    "build:web": "npm run build --workspace=@nexus/web",
    "start:api": "npm run start --workspace=@nexus/api"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
