{
  "buildCommand": "node build.js",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/records/:id", "destination": "/api/records/[id]" },
    { "source": "/t/:slug", "destination": "/tenant.html" },
    { "source": "/(.+\\.js)", "destination": "/api/asset-shim?ext=js&name=$1" },
    { "source": "/(.+\\.css)", "destination": "/api/asset-shim?ext=css&name=$1" }
  ],
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/(.*-[A-Z0-9]{8}\\.(?:js|css))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/((?!.*-[A-Z0-9]{8}\\.).*\\.(?:js|css))",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}
