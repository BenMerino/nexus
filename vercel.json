{
  "buildCommand": "node build.js",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/records/:id", "destination": "/api/records/[id]" },
    { "source": "/t/:slug", "destination": "/tenant.html" }
  ],
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ]
}
