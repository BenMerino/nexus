{
  "name": "@nexus/api",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run copy-assets",
    "copy-assets": "node -e \"const fs=require('fs'),p=require('path'),s='src/db/migrations',d='dist/src/db/migrations';fs.mkdirSync(d,{recursive:true});for(const f of fs.readdirSync(s))if(f.endsWith('.sql'))fs.copyFileSync(p.join(s,f),p.join(d,f))\"",
    "start": "node dist/index.js",
    "dev": "npm run build && node --watch dist/index.js",
    "dev:tsc": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "express": "^4.21.2",
    "pg": "^8.20.0",
    "typescript": "^5.7.2",
    "ws": "^8.21.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  }
}
