# Caddyfile for Nexus on Railway. Same shape as Zincro's: one file, both
# frontend services (none yet, just nexus-web today) parameterize routing
# via env vars set per-service by scripts/railway-bootstrap.sh.
#
# - /api/* → reverse_proxy to the API service over Railway's internal
#   network. {$API_INTERNAL_URL} is e.g. nexus.railway.internal:8080.
# - /(.+\.js) and /(.+\.css) at the root → asset-shim, which serves a
#   one-shot reload payload to clients on stale cached HTML referencing
#   asset filenames from a previous build. Mirrors the vercel.json rewrite
#   that ran on Vercel; without it, those clients see 404s and can't
#   self-recover.
# - /t/:slug → tenant.html (mirrors the Vercel rewrite).
# - Everything else → static SPA: serve {$RAILPACK_SPA_OUTPUT_DIR},
#   fall back to /dashboard.html (root index) for unknown paths.

{
	auto_https off
	admin off
}

:{$PORT} {
	encode gzip

	handle /api/* {
		reverse_proxy {$API_INTERNAL_URL}
	}

	# Tenant slug rewrite (was a Vercel rewrite to /tenant.html).
	@tenant path_regexp tenant ^/t/[^/]+$
	rewrite @tenant /tenant.html

	# Public entity views: /t/:slug/{faculties,academics,papers,journals} → the
	# same tenant.html shell (it client-routes by URL). Shareable, deep-linkable.
	# Listed before the author rule so /a/:orcid isn't captured by a generic seg.
	@tenantEntity path_regexp tenantEntity ^/t/[^/]+/(faculties|academics|papers|journals)$
	rewrite @tenantEntity /tenant.html

	# Individual academic profile: /t/:slug/a/:orcid → author.html.
	@authorPage path_regexp authorPage ^/t/[^/]+/a/[^/]+$
	rewrite @authorPage /author.html

	# Per-tenant social meta: the BUILT tenant/author HTML carries a
	# [[% ... %]] marker (vite.config injects it at build time); this pass
	# replaces it with the API-composed <meta> fragment via an internal
	# subrequest (httpInclude → /api/public-meta, routed through the /api/*
	# proxy above). Delimiters are deliberately BRACE-FREE: Railway's
	# railpack pre-parses this Caddyfile as a Go template, so any literal
	# double-brace here fails the whole deploy ("unexpected % in command"),
	# and brace-free also means bundled-JS braces can never collide.
	# /api/public-meta always answers 200 (empty on error), so this cannot
	# fail the page render.
	@pubHtml path /tenant.html /author.html
	templates @pubHtml {
		between [[% %]]
	}

	# Asset-shim catch-all for stale-HTML clients. Matches *.js / *.css at
	# the root that didn't hit the static file_server. Forwards to the API
	# which serves a tiny reload payload from /api/asset-shim.
	@stale_js path_regexp js ^/[^/]+\.js$
	handle @stale_js {
		reverse_proxy {$API_INTERNAL_URL} {
			rewrite /api/asset-shim?ext=js&name={uri}
		}
	}
	@stale_css path_regexp css ^/[^/]+\.css$
	handle @stale_css {
		reverse_proxy {$API_INTERNAL_URL} {
			rewrite /api/asset-shim?ext=css&name={uri}
		}
	}

	# Long-cache hashed assets, no-cache HTML.
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"
	# Hashed assets are immutable, so a request that misses the file_server is
	# a STALE hash from cached HTML — serve a real 404, never the index.html
	# SPA fallback (a module script fed text/html throws and blanks the page).
	handle /assets/* {
		root * {$RAILPACK_SPA_OUTPUT_DIR}
		file_server
	}
	# Geo data (world choropleth geometry, ~78KB) — not content-hashed but
	# effectively immutable; a day of browser cache stops the re-download.
	@geo path /geo/*
	header @geo Cache-Control "public, max-age=86400"
	# NB: `header` runs BEFORE `rewrite` in Caddy's directive order, so this
	# matcher must list the PRE-rewrite shapes: explicit *.html, the SPA root,
	# and the /t/* public routes (tenant + academic profiles). Without /t/*
	# those responses ship with no Cache-Control, browsers heuristically cache
	# the HTML, and after a deploy it references deleted asset hashes → blank
	# page (exactly the failure seen after rapid redeploys).
	@html path *.html / /t/*
	header @html Cache-Control "no-store, no-cache, must-revalidate"

	handle {
		root * {$RAILPACK_SPA_OUTPUT_DIR}
		# try_files order:
		#   1. {path}            — exact file (incl. legacy .html files like
		#                          /dashboard.html, /proyectos.html during the
		#                          phased migration; legacy nav still links to
		#                          these explicitly).
		#   2. /index.html       — React Router catch-all. Migrated routes
		#                          (e.g. /dashboard, /login) render here.
		#                          A {path}.html step would be wrong: it would
		#                          rewrite /dashboard → dashboard.html, which
		#                          is a redirect file pointing back at
		#                          /dashboard, producing a redirect loop.
		try_files {path} /index.html
		file_server
	}
}
